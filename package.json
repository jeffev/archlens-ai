{
  "name": "archlens-ai",
  "version": "0.1.0",
  "description": "Interactive architecture visualization powered by Claude Code",
  "type": "module",
  "bin": {
    "archlens-ai": "./dist/cli.js",
    "archlens": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "install.sh",
    "install.ps1",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffev/archlens-ai.git"
  },
  "homepage": "https://jeffev.github.io/archlens-ai",
  "bugs": {
    "url": "https://github.com/jeffev/archlens-ai/issues"
  },
  "keywords": [
    "architecture",
    "visualization",
    "claude",
    "ai",
    "cli",
    "diagram",
    "static-analysis"
  ],
